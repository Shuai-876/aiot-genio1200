{
  "__inputs": [
    {
      "name": "DS_POSTGRESQL",
      "label": "PostgreSQL",
      "type": "datasource",
      "pluginId": "postgres",
      "pluginName": "PostgreSQL"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "9.0.0" },
    { "type": "datasource", "id": "postgres", "name": "PostgreSQL", "version": "1.0.0" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" }
  ],
  "description": "YOLO detection count per class over time",
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "refresh": "5s",
  "schemaVersion": 39,
  "tags": ["aiot", "safety"],
  "time": { "from": "now-1h", "to": "now" },
  "timezone": "browser",
  "title": "AIoT 偵測類別趨勢",
  "uid": "aiot-detection-trend",
  "version": 1,
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "各類別偵測次數（每分鐘）",
      "description": "X軸=時間，Y軸=偵測次數，每條線代表一個偵測類別",
      "gridPos": { "h": 20, "w": 24, "x": 0, "y": 0 },
      "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "fillOpacity": 10,
            "gradientMode": "opacity",
            "showPoints": "auto",
            "pointSize": 5,
            "spanNulls": true,
            "axisBorderShow": false,
            "axisColorMode": "text",
            "scaleDistribution": { "type": "linear" },
            "hideFrom": { "legend": false, "tooltip": false, "viz": false }
          },
          "unit": "short",
          "min": 0,
          "decimals": 0
        }
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "table",
          "placement": "right",
          "calcs": ["sum", "max", "mean"],
          "showLegend": true
        }
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "${DS_POSTGRESQL}" },
          "rawSql": "SELECT\n  date_trunc('minute', timestamp) AS \"time\",\n  \"className\" AS metric,\n  COUNT(*) AS value\nFROM \"Detections\"\nWHERE $__timeFilter(timestamp)\nGROUP BY 1, 2\nORDER BY 1",
          "format": "time_series",
          "refId": "A"
        }
      ]
    }
  ]
}
